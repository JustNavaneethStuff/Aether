# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Data
POSTGRES_URL=postgresql+asyncpg://aether:aether@localhost:5432/aether
REDIS_URL=redis://localhost:6379/0

# Service URLs (local development)
API_GATEWAY_URL=http://localhost:8000
ORCHESTRATOR_URL=http://localhost:8001
MEMORY_SERVICE_URL=http://localhost:8002
RESPONSE_BUILDER_URL=http://localhost:8003
KNOWLEDGE_SERVICE_URL=http://localhost:8004

# Auth (Phase 2)
AUTH_ENABLED=false
JWT_SECRET=aether-dev-secret-change-in-production
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Agent URLs
AGENT_PLANNER_URL=http://localhost:8010
AGENT_RESEARCH_URL=http://localhost:8011
AGENT_CRITIC_URL=http://localhost:8012
AGENT_SUMMARIZER_URL=http://localhost:8013
AGENT_CODE_URL=http://localhost:8014
AGENT_DATA_ANALYSIS_URL=http://localhost:8015
AGENT_FACT_CHECKER_URL=http://localhost:8016
AGENT_MEMORY_MANAGER_URL=http://localhost:8017
AGENT_TOOL_EXECUTOR_URL=http://localhost:8018

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aether
LOG_LEVEL=INFO
LOG_FORMAT=json

# Service identity
SERVICE_NAME=aether
